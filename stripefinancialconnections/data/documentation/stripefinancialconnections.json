{"primaryContentSections":[{"kind":"content","content":[{"text":"Table of contents","level":2,"type":"heading","anchor":"Table-of-contents"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"#Features","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"#Requirements","isActive":true,"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"#Getting-started","type":"reference"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"#Integration","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"#Example","type":"reference"}]}]}]}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"#Manual-linking"}],"type":"paragraph"}]}]},{"text":"Features","level":2,"type":"heading","anchor":"Features"},{"inlineContent":[{"inlineContent":[{"text":"Prebuilt UI","type":"text"}],"type":"strong"},{"type":"text","text":": We provide "},{"isActive":true,"identifier":"https:\/\/stripe.dev\/stripe-ios\/stripe-financialconnections\/Classes\/FinancialConnectionsSheet.html","type":"reference"},{"type":"text","text":", a prebuilt UI that combines all the steps required for your users to linking their external financial accounts to your business."}],"type":"paragraph"},{"inlineContent":[{"text":"Data retrieved through Financial Connections can help you unlock a variety of use cases, including:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Tokenized account and routing numbers let you instantly verify bank accounts for ACH Direct Debit payments."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Real-time balance data helps you avoid fees from insufficient funds failures before initiating a bank-based payment or wallet transfer."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Account ownership information, such as the name and address of the bank accountholder, helps you mitigate fraud when onboarding a customer or merchant.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Transactions data that you can use to help users track expenses, handle bills, manage their finances, and take control of their financial well-being.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Transactions and balance data helps you speed up underwriting and improve access to credit and other financial services."}]}]}]},{"text":"Requirements","level":2,"type":"heading","anchor":"Requirements"},{"inlineContent":[{"text":"The Stripe Financial Connections iOS SDK is compatible with apps targeting iOS 12.0 or above.","type":"text"}],"type":"paragraph"},{"text":"Getting started","level":2,"type":"heading","anchor":"Getting-started"},{"text":"Integration","level":3,"type":"heading","anchor":"Integration"},{"inlineContent":[{"text":"Get started with Stripe Financial Connections ","type":"text"},{"identifier":"https:\/\/stripe.com\/docs\/financial-connections\/other-data-powered-products?platform=ios","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"https:\/\/github.com\/stripe\/stripe-ios\/tree\/26.7.999\/StripeFinancialConnections\/..\/Example\/FinancialConnections%20Example","isActive":true,"type":"reference"},{"text":", or ","type":"text"},{"identifier":"https:\/\/stripe.dev\/stripe-ios\/stripe-financialconnections\/index.html","isActive":true,"type":"reference"},{"text":" for fine-grained documentation of all the classes and methods in the SDK.","type":"text"}],"type":"paragraph"},{"text":"Example","level":3,"type":"heading","anchor":"Example"},{"inlineContent":[{"overridingTitleInlineContent":[{"text":"Financial Connections Example","type":"text"}],"type":"ref