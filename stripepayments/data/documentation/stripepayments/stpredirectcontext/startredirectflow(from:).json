{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@objc","kind":"attribute"},{"text":"(startRedirectFlowFromViewController:) ","kind":"text"},{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"startRedirectFlow","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"from"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"presentingViewController"},{"kind":"text","text":": "},{"text":"UIViewController","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UIViewController"},{"kind":"text","text":")"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This method does nothing if the context is not in the"},{"text":" ","type":"text"},{"code":"STPRedirectContextStateNotStarted","type":"codeVoice"},{"type":"text","text":" state."}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Parameter presentingViewController: The view controller to present the Safari"},{"text":" ","type":"text"},{"type":"text","text":"view controller from."}],"type":"paragraph"}]}]}],"name":"Note"}]}],"identifier":{"url":"doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments\/STPRedirectContext\/startRedirectFlow(from:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments","doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments\/STPRedirectContext"]]},"variants":[{"paths":["\/documentation\/stripepayments\/stpredirectcontext\/startredirectflow(from:)"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/stripepayments\/stpredirectcontext\/startredirectflow(from:)"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Starts a redirect flow."},{"type":"text","text":" "},{"text":"You must ensure that your app delegate listens for  the ","type":"text"},{"type":"codeVoice","code":"returnURL"},{"text":" that you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"set on the Stripe object, and forwards it to the Stripe SDK so that the"},{"text":" ","type":"text"},{"type":"text","text":"context can be notified when the redirect is completed and dismiss the"},{"type":"text","text":" "},{"text":"view controller. See ","type":"text"},{"type":"codeVoice","code":"StripeAPI.handleURLCallback(with url:)"},{"type":"text","text":" "},{"type":"text","text":"The context will listen for both received URLs and app open notifications"},{"type":"text","text":" "},{"text":"and fire its completion block when either the URL is received, or the next","type":"text"},{"text":" ","type":"text"},{"text":"time the app is foregrounded.","type":"text"},{"text":" ","type":"text"},{"text":"The context will initiate the flow by presenting a SFSafariViewController","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instance from the passsed in view controller. If you want more manual control"},{"text":" ","type":"text"},{"type":"text","text":"over the redirect method, you can use "},{"type":"codeVoice","code":"startSafariViewControllerRedirectFlowFromViewController"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"code":"startSafariAppRedirectFlow","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"If the redirect supports a native app, and that app is is installed on the user’s"},{"type":"text","text":" "},{"type":"text","text":"device, this call will do a direct app-to-app redirect instead of showing"},{"text":" ","type":"text"},{"text":"a web url.","type":"text"}],"kind":"symbol","sections":[],"metadata":{"role":"symbol","title":"startRedirectFlow(from:)","symbolKind":"method","roleHeading":"Instance Method","navigatorTitle":[{"text":"startRedirectFlowFromViewController:","kind":"identifier"}],"externalID":"c:@M@StripePayments@objc(cs)STPRedirectContext(im)startRedirectFlowFromViewController:","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"startRedirectFlow"},{"text":"(","kind":"text"},{"text":"from","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)UIViewController","text":"UIViewController","kind":"typeIdentifier"},{"kind":"text","text":")"}],"modules":[{"name":"StripePayments"}]},"references":{"doc://com.stripe.stripe-payments/documentation/StripePayments":{"title":"StripePayments","type":"topic","kind":"symbol","role":"collection","abstract":[{"text":"The StripePayments module contains bindings for the Stripe Payments API.","type":"text"}],"identifier":"doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments","url":"\/documentation\/stripepayments"},"doc://com.stripe.stripe-payments/documentation/StripePayments/STPRedirectContext/startRedirectFlow(from:)":{"navigatorTitle":[{"text":"startRedirectFlowFromViewController:","kind":"identifier"}],"url":"\/documentation\/stripepayments\/stpredirectcontext\/startredirectflow(from:)","kind":"symbol","type":"topic","role":"symbol","title":"startRedirectFlow(from:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"startRedirectFlow"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"from"},{"text":": ","kind":"text"},{"text":"UIViewController","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UIViewController"},{"text":")","kind":"text"}],"abstract":[{"text":"Starts a redirect flow.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You must ensure that your app delegate listens for  the "},{"code":"returnURL","type":"codeVoice"},{"type":"text","text":" that you"},{"type":"text","text":" "},{"type":"text","text":"set on the Stripe object, and forwards it to the Stripe SDK so that the"},{"text":" ","type":"text"},{"text":"context can be notified when the redirect is completed and dismiss the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"view controller. See "},{"code":"StripeAPI.handleURLCallback(with url:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"The context will listen for both received URLs and app open notifications","type":"text"},{"type":"text","text":" "},{"text":"and fire its completion block when either the URL is received, or the next","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time the app is foregrounded."},{"type":"text","text":" "},{"type":"text","text":"The context will initiate the flow by presenting a SFSafariViewController"},{"type":"text","text":" "},{"text":"instance from the passsed in view controller. If you want more manual control","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"over the redirect method, you can use "},{"code":"startSafariViewControllerRedirectFlowFromViewController","type":"codeVoice"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"type":"codeVoice","code":"startSafariAppRedirectFlow"},{"type":"text","text":" "},{"text":"If the redirect supports a native app, and that app is is installed on the user’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"device, this call will do a direct app-to-app redirect instead of showing"},{"type":"text","text":" "},{"type":"text","text":"a web url."}],"identifier":"doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments\/STPRedirectContext\/startRedirectFlow(from:)"},"doc://com.stripe.stripe-payments/documentation/StripePayments/STPRedirectContext":{"type":"topic","url":"\/documentation\/stripepayments\/stpredirectcontext","kind":"symbol","abstract":[{"type":"text","text":"This is a helper class for handling redirects associated with STPSource and"},{"type":"text","text":" "},{"type":"text","text":"STPPaymentIntents."},{"type":"text","text":" "},{"text":"Init and retain an instance with the Source or PaymentIntent you want to handle,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then choose a redirect method. The context will fire the completion handler"},{"text":" ","type":"text"},{"text":"when the redirect completes.","type":"text"},{"text":" ","type":"text"},{"text":"Due to the nature of iOS, very little concrete information can be gained","type":"text"},{"type":"text","text":" "},{"text":"during this process, as all actions take place in either the Safari app","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or the sandboxed SFSafariViewController class. The context attempts to"},{"text":" ","type":"text"},{"type":"text","text":"detect when the user has completed the necessary redirect action by listening"},{"text":" ","type":"text"},{"type":"text","text":"for both app foregrounds and url callbacks received in the app delegate."},{"type":"text","text":" "},{"text":"However, it is possible the when the redirect is “completed”, the user may","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have not actually completed the necessary actions to authorize the charge."},{"type":"text","text":" "},{"type":"text","text":"You should not use either this class, nor "},{"type":"codeVoice","code":"STPAPIClient"},{"text":", as a way","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to determine when you should charge the Source or to determine if the redirect"},{"type":"text","text":" "},{"type":"text","text":"was successful. Use Stripe webhooks on your backend server to listen for Source"},{"type":"text","text":" "},{"text":"state changes and to make the charge.","type":"text"}],"identifier":"doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments\/STPRedirectContext","navigatorTitle":[{"text":"STPRedirectContext","kind":"identifier"}],"title":"STPRedirectContext","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"STPRedirectContext"}]}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"path":"\/identifier\/interfaceLanguage","value":"occ","op":"replace"},{"path":"\/metadata\/roleHeading","value":"Instance Method","op":"replace"},{"value":"startRedirectFlowFromViewController:","op":"replace","path":"\/metadata\/title"},{"op":"replace","path":"\/metadata\/symbolKind","value":"method"},{"op":"replace","path":"\/metadata\/fragments","value":[{"text":"- ","kind":"text"},{"kind":"identifier","text":"startRedirectFlowFromViewController:"}]},{"path":"\/topicSections","op":"add","value":null},{"path":"\/relationshipsSections","op":"add","value":null},{"op":"add","path":"\/seeAlsoSections","value":null},{"op":"replace","path":"\/primaryContentSections\/0","value":{"kind":"declarations","declarations":[{"tokens":[{"text":"- (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"startRedirectFlowFromViewController:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UIViewController","text":"UIViewController"},{"text":" *) ","kind":"text"},{"text":"presentingViewController","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]}},{"op":"replace","value":"startRedirectFlowFromViewController:","path":"\/references\/doc:~1~1com.stripe.stripe-payments~1documentation~1StripePayments~1STPRedirectContext~1startRedirectFlow(from:)\/title"},{"path":"\/references\/doc:~1~1com.stripe.stripe-payments~1documentation~1StripePayments~1STPRedirectContext~1startRedirectFlow(from:)\/fragments","op":"replace","value":[{"kind":"text","text":"- "},{"kind":"identifier","text":"startRedirectFlowFromViewController:"}]},{"path":"\/references\/doc:~1~1com.stripe.stripe-payments~1d