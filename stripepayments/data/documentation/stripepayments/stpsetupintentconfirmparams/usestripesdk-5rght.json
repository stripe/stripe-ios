{"sections":[],"metadata":{"symbolKind":"property","externalID":"s:14StripePayments27STPSetupIntentConfirmParamsC03useA3SDKSbSgvp","roleHeading":"Instance Property","title":"useStripeSDK","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useStripeSDK"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":"?"}],"role":"symbol","modules":[{"name":"StripePayments"}]},"identifier":{"url":"doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments\/STPSetupIntentConfirmParams\/useStripeSDK-5rght","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"A boolean number to indicate whether you intend to use the Stripe SDK’s functionality to handle any SetupIntent next actions."},{"type":"text","text":" "},{"type":"text","text":"If set to false, STPSetupIntent.nextAction will only ever contain a redirect url that can be opened in a webview or mobile browser."},{"type":"text","text":" "},{"type":"text","text":"When set to true, the nextAction may contain information that the Stripe SDK can use to perform native authentication within your"},{"type":"text","text":" "},{"type":"text","text":"app."}],"variants":[{"paths":["\/documentation\/stripepayments\/stpsetupintentconfirmparams\/usestripesdk-5rght"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments","doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments\/STPSetupIntentConfirmParams"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"useStripeSDK","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"platforms":["iOS"],"languages":["swift"]}]}],"references":