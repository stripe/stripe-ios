An object representing parameters to confirm a SetupIntent object."},{"type":"text","text":" "},{"type":"text","text":"For example, you would confirm a SetupIntent when a customer hits the “Save” button on a payment method management view in your app."},{"text":" ","type":"text"},{"type":"text","text":"If the selected payment method does not require any additional steps from the customer, the SetupIntent’s status will transition to "},{"code":"STPSetupIntentStatusSucceeded","type":"codeVoice"},{"text":".  Otherwise, it will transition to ","type":"text"},{"code":"STPSetupIntentStatusRequiresAction","type":"codeVoice"},{"text":", and suggest additional actions via ","type":"text"},{"type":"codeVoice","code":"nextAction"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Instead of passing this to ","type":"text"},{"code":"STPAPIClient.confirmSetupIntent(...)","type":"codeVoice"},{"text":" directly, we recommend using ","type":"text"},{"code":"STPPaymentHandler","type":"codeVoice"},{"type":"text","text":" to handle any additional steps for you."}],"title":"STPSetupIntentConfirmParams","kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"STPSetupIntentConfirmParams"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"STPSetupIntentConfirmParams"}]},"doc://com.stripe.stripe-payments/documentation/StripePayments/STPRadarOptions":{"type":"topic","url":"\/documentation\/stripepayments\/stpradaroptions","identifier":"doc:\/\/com.stripe.stripe-payments\/documentation\/StripePayments\/STPRadarOptions","abstract":[{"type":"text","text":"Values for STPRadarOptions"}],"title":"STPRadarOptions","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"STPRadarOptions"}]},"doc://com.stripe.stripe-payments/documentation/StripePayments":{"url":"\/documentation\/stripepayments","abstract":[{"type":"text","text":"The StripePayments module contains bindings for the Stripe Payment