ration-swift.struct\/termsDisplay","abstract":[{"type":"text","text":"A map for specifying when legal agreements are displayed for each payment method type."},{"type":"text","text":" "},{"type":"text","text":"If the payment method is not specified in the list, the TermsDisplay value will default to "},{"type":"codeVoice","code":".automatic"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Valid payment method types include:"},{"type":"text","text":" "},{"type":"text","text":".card"}],"kind":"symbol"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/PaymentSheet/Configuration-swift.struct":{"identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/PaymentSheet\/Configuration-swift.struct","title":"PaymentSheet.Configuration","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Configuration"}],"abstract":[{"text":"Configuration for PaymentSheet","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"Configuration"}],"url":"\/documentation\/stripepaymentsheet\/paymentsheet\/configuration-swift.struct","kind":"symbol"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/PaymentSheet/Configuration-swift.struct/paymentMethodOrder":{"url":"\/documentation\/stripepaymentsheet\/paymentsheet\/configuration-swift.struct\/paymentmethodorder","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"paymentMethodOrder","kind":"identifier"},{"text":": [","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"]?","kind":"text"}],"abstract":[{"type":"text","text":"By default, PaymentSheet will use a dynamic ordering that optimizes payment method display for the customer."},{"type":"text","text":" "},{"type":"text","text":"You can override the default order in which payment methods are displayed in PaymentSheet with a list of payment method types."},{"type":"text","text":" "},{"type":"text","text":"See https:\/\/stripe.com\/docs\/api\/payment_methods\/object#payment_method_object-type for the list of valid types.  You may also pass external payment methods."}],"kind":"symbol","type":"topic","title":"paymentMethodOrder","role":"symbol","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/PaymentSheet\/Configuration-swift.struct\/paymentMethodOrder"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/PaymentSheet/Configuration-swift.struct/cardBrandAcceptance":{"abstract":[{"type":"text","text":"By default, PaymentSheet will accept all supported cards by Stripe."},{"type":"text","text":" "},{"type":"text","text":"You can specify card brands PaymentSheet should block disallow or allow payment for by providing an array of those card brands."},{"type":"text","text":" "},{"type":"text","text":"Note: For Apple Pay, the list of supported card brands is determined by combining "},{"type":"codeVoice","code":"StripeAPI.supportedPKPaymentNetworks()"},{"type":"text","text":" with "},{"type":"codeVoice","code":"StripeAPI.additionalEnabledApplePayNetworks"},{"type":"text","text":" and then applying the "},{"type":"codeVoice","code":"cardBrandAcceptance"},{"type":"text","text":" filter. This filtered list is then assigned to "},{"type":"codeVoice","code":"PKPaymentRequest.supportedNetworks"},{"type":"text","text":", ensuring that only the allowed card brands are available for Apple Pay transactions. Any "},{"type":"codeVoice","code":"PKPaymentNetwork"},{"type":"text","text":" that does not correspond to a "},{"type":"codeVoice","code":"BrandCategory"},{"type":"text","text":" will be blocked if you have specified an allow list, or will not be blocked if you have specified a disallow list."},{"type":"text","text":" "},{"type":"text","text":"Note: This is only a client-side solution."},{"type":"text","text":" "},{"type":"text","text":"Note: Card brand fi