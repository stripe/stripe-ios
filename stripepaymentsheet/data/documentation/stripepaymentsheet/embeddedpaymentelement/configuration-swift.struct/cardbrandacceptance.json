 by Stripe."},{"type":"text","text":" "},{"type":"text","text":"You can specify card brands the embedded payment element should block disallow or allow payment for by providing an array of those card brands."},{"type":"text","text":" "},{"type":"text","text":"Note: For Apple Pay, the list of supported card brands is determined by combining "},{"type":"codeVoice","code":"StripeAPI.supportedPKPaymentNetworks()"},{"type":"text","text":" with "},{"type":"codeVoice","code":"StripeAPI.additionalEnabledApplePayNetworks"},{"type":"text","text":" and then applying the "},{"type":"codeVoice","code":"cardBrandAcceptance"},{"type":"text","text":" filter. This filtered list is then assigned to "},{"type":"codeVoice","code":"PKPaymentRequest.supportedNetworks"},{"type":"text","text":", ensuring that only the allowed card brands are available for Apple Pay transactions. Any "},{"type":"codeVoice","code":"PKPaymentNetwork"},{"type":"text","text":" that does not correspond to a "},{"type":"codeVoice","code":"BrandCategory"},{"type":"text","text":" will be blocked if you have specified an allow list, or will not be blocked if you have specified a disallow list."},{"type":"text","text":" "},{"type":"text","text":"Note: This is only a client-side solution."},{"type":"text","text":" "},{"type":"text","text":"Note: Card brand filtering is not currently supported by Link."}],"references":{"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/EmbeddedPaymentElement/CardBrandAcceptance":{"kind":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CardBrandAcceptance","kind":"identifier"}],"role":"symbol","abstract":[],"type":"topic","title":"EmbeddedPaymentElement.CardBrandAcceptance","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/EmbeddedPaymentElement\/CardBrandAcceptance","navigatorTitle":[{"text":"CardBrandAcceptance","kind":"identifier"}],"url":"\/documentation\/stripepaymentsheet\/e