-swift.struct\/formSheetAction-swift.property","kind":"symbol","type":"topic","url":"\/documentation\/stripepaymentsheet\/embeddedpaymentelement\/configuration-swift.struct\/formsheetaction-swift.property"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/EmbeddedPaymentElement/Configuration-swift.struct/link":{"type":"topic","abstract":[{"type":"text","text":"Configuration related to Link"}],"url":"\/documentation\/stripepaymentsheet\/embeddedpaymentelement\/configuration-swift.struct\/link","title":"link","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/EmbeddedPaymentElement\/Configuration-swift.struct\/link","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"link"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18StripePaymentSheet08EmbeddedB7ElementC17LinkConfigurationa","kind":"typeIdentifier","text":"LinkConfiguration"}],"kind":"symbol"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/EmbeddedPaymentElement/Configuration-swift.struct/primaryButtonColor":{"abstract":[{"text":"The color of the Buy or Add button. Defaults to ","type":"text"},{"code":".systemBlue","type":"codeVoice"},{"text":" when ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}],"role":"symbol","type":"topic","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/EmbeddedPaymentElement\/Configuration-swift.struct\/primaryButtonColor","kind":"symbol","title":"primaryButtonColor","url":"\/documentation\/stripepaymentsheet\/embeddedpaymentelement\/configuration-swift.struct\/primarybuttoncolor","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"primaryButtonColor"},{"kind":"text","text":": "},{"preciseIdentifier":"c:objc(cs)UIColor","kind":"typeIdentifier","text":"UIColor"},{"kind":"text","text":"?"}]},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/EmbeddedPaymentElement/Configuration-swift.struct/cardBrandAcceptance":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cardBrandAcceptance","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18StripePaymentSheet08EmbeddedB7ElementC19CardBrandAcceptancea","text":"CardBrandAcceptance","kind":"typeIdentifier"}],"abstract":[{"text":"By default, the embedded payment element will accept all supported cards by Stripe.","type":"text"},{"text":" ","type":"text"},{"text":"You can specify card brands the embedded payment element should block disallow or allow payment for by providing an array of those card brands.","type":"text"},{"text":" ","type":"text"},{"text":"Note: For Apple Pay, the list of supported card brands is determined by combining ","type":"text"},{"code":"StripeAPI.supportedPKPaymentNetworks()","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"StripeAPI.additionalEnabledApplePayNetworks","type":"codeVoice"},{"text":" and then applying the ","type":"text"},{"code":"cardBrandAcceptance","type":"codeVoice"},{"text":" filter. This filtered list is then assigned to ","type":"text"},{"code":"PKPaymentRequest.supportedNetworks","type":"codeVoice"},{"text":", ensuring that only the allowed card brands are available for Apple Pay transactions. Any ","type":"text"},{"code":"PKPaymentNetwork","type":"codeVoice"},{"text":" that does not correspond to a ","type":"text"},{"code":"BrandCategory","type":"codeVoice"},{"text":" will be blocked if you have specified an allow list, or will not be blocked if you have specified a disallow list.","type":"text"},{"text":" ","type":"text"},{"text":"Note: This is only a client-side solution.","type":"text"},{"text":" ","type":"text"},{"text":"Note: Card brand filtering is not currently supported by Link.","type":"text"}],"url":"\/documentation\/stripepaymentsheet\/embeddedpaymentelement\/configuration-swift.struct\/cardbrandacceptance","kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/EmbeddedPaymentElement\/Configuration-swift.struct\/cardBrandAcceptance","role":"symbol","title":"cardBrandAcceptance","type":"topic"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/EmbeddedPaymentElement/Configuration-swift.struct/style":{"identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/EmbeddedPaymentElement\/Configuration-swift.struct\/style","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"style","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18StripePaymentSheet08EmbeddedB7ElementC18UserInterfaceStylea","text":"UserInterfaceStyle","kind":"typeIdentifier"}],"kind":"symbol","url":"\/documentation\/stripepaymentsheet\/embeddedpaymentelement\/configuration-swift.struct\/style","abstract":[{"type":"text","text":"The color styling to use for PaymentSheet UI"},{"type":"text","text":" "},{"type":"text","text":"Default value is SheetStyle.automatic"}],"title":"style","type":"topic"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet":{"abstract":[{"text":"PaymentSheet is a prebuilt UI that combines all the steps required to pay - collecting payment details, billing details, and confirming the payment - into a single sheet that displays on top of your app.","type":"text"}],"type":"topic","url":"\/documentation\/stripepaymentsheet","kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet","role":"collection","title":"StripePaymentSheet"}}}