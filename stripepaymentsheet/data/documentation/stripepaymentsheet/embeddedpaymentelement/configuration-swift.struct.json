y combining ","type":"text"},{"type":"codeVoice","code":"StripeAPI.supportedPKPaymentNetworks()"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"StripeAPI.additionalEnabledApplePayNetworks"},{"text":" and then applying the ","type":"text"},{"type":"codeVoice","code":"cardBrandAcceptance"},{"text":" filter. This filtered list is then assigned to ","type":"text"},{"type":"codeVoice","code":"PKPaymentRequest.supportedNetworks"},{"text":", ensuring that only the allowed card brands are available for Apple Pay transactions. Any ","type":"text"},{"type":"codeVoice","code":"PKPaymentNetwork"},{"text":" that does not correspond to a ","type":"text"},{"type":"codeVoice","code":"BrandCategory"},{"text":" will be blocked if you have specified an allow list, or will not be blocked if you have specified a disallow list.","type":"text"},{"text":" ","type":"text"},{"text":"Note: This is only a client-side solution.","type":"text"},{"text":" ","type":"text"},{"text":"Note: Card brand filtering is not currently supported by Link.","type":"text"}],"type":"topic","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/EmbeddedPaymentElement\/Configuration-swift.struct\/cardBrandAcceptance"},"https://stripe.com/docs/api/payment_intents/object#payment_intent_object-shipping":{"url":"https:\/\/stripe.com\/docs\/api\/payment_intents\/object#payment_intent_object-shipping","title":"attached to the PaymentIntent","type":"link","identifier":"https:\/\/stripe.com\/docs\/api\/payment_intents\/object#payment_intent_object-shipping","titleInlineContent":[{"text":"attached to the PaymentIntent","type":"text"}]}}}