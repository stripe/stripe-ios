/embeddedpaymentelement\/configuration-swift.struct\/cardbrandacceptance","abstract":[{"type":"text","text":"By default, the embedded payment element will accept all supported cards by Stripe."},{"type":"text","text":" "},{"type":"text","text":"You can specify card brands the embedded payment element should block disallow or allow payment for by providing an array of those card brands."},{"type":"text","text":" "},{"type":"text","text":"Note: For Apple Pay, the list of supported card brands is determined by combining "},{"code":"StripeAPI.supportedPKPaymentNetworks()","type":"codeVoice"},{"type":"text","text":" with "},{"code":"StripeAPI.additionalEnabledApplePayNetworks","type":"codeVoice"},{"text":" and then applying the ","type":"text"},{"type":"codeVoice","code":"cardBrandAcceptance"},{"text":" filter. This filtered list is then assigned to ","type":"text"},{"type":"codeVoice","code":"PKPaymentRequest.supportedNetworks"},{"type":"text","text":", ensuring that only the allowed card brands are available for Apple Pay transactions. Any "},{"type":"codeVoice","code":"PKPaymentNetwork"},{"type":"text","text":" that does not correspond to a "},{"type":"codeVoice","code":"BrandCategory"},{"type":"text","text":" will be blocked if you have specified an allow list, or will not be blocked if you have specified a disallow list."},{"type":"text","text":" "},{"type":"text","text":"Note: This is only a client-side solution."},{"type":"text","text":" "},{"type":"text","text":"Note: Card brand filtering is not currently supported by Link."}],"identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/EmbeddedPaymentElement\/Configuration-swift.struct\/cardBrandAcceptance","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cardBrandAcceptance","kind":"identifier"},{"text":": ","kind":"text"},{"text":"CardBrandAcceptance","kind":"typeIdentifier","preciseIdentifier":"s:18StripePaymentSheet08EmbeddedB7ElementC19CardBrandAc