ntifier"},{"text":")","kind":"text"}],"modules":[{"name":"StripePaymentSheet","relatedModules":["StripePayments"]}],"roleHeading":"Instance Method","role":"symbol","externalID":"c:@CM@StripePayments@objc(cs)STPRedirectContext(im)safariViewController:initialLoadDidRedirectToURL:","symbolKind":"method","extendedModule":"StripePayments"},"abstract":[{"type":"text","text":"Inherited from "},{"type":"codeVoice","code":"SFSafariViewControllerDelegate.safariViewController(_:initialLoadDidRedirectTo:)"},{"text":".","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPRedirectContext\/safariViewController(_:initialLoadDidRedirectTo:)"},"references":{"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/STPRedirectContext/safariViewController(_:initialLoadDidRedirectTo:)":{"identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPRedirectContext\/safariViewController(_:initialLoadDidRedirectTo:)","title":"safariViewController(_:initialLoadDidRedirectTo:)","url":"\/documentation\/stripepaymentsheet\/stpredirectcontext\/safariviewcontroller(_:initialloaddidredirectto:)","role":"symbol","abstract":[],"kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"safariViewController"},{"text":"(","kind":"text"},{"text":"SFSafariViewController","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)SFSafariViewController"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"initialLoadDidRedirectTo"},{"text":": ","kind":"text"},{"text":"URL","kind":"typeIdentifier","preciseIdentifier":"s:10Foundation3URLV"},{"text":")","kind":"text"}]},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/STPRedirectContext":{"kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPRedirectContext","title":"STPRedirectContext","navigatorTitle":[{"text":"STPRedirectContext","kind":"identifier"}],"url":"\/documentation\/stripepaymentsheet\/stpredirectcontext","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"STPRedirectContext","kind":"identifier"}],"abstract":[{"type":"text","text":"This is a helper class for handling redirects associated with STPSource and"},{"text":" ","type":"text"},{"text":"STPPaymentIntents.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Init and retain an instance with the Source or PaymentIntent you want to handle,"},{"text":" ","type":"text"},{"type":"text","text":"then choose a redirect method. The context will fire the completion handler"},{"text":" ","type":"text"},{"text":"when the redirect completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Due to the nature of iOS, very little concrete information can be gained"},{"type":"text","text":" "},{"text":"during this process, as all actions take place in either the Safari app","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or the sandboxed SFSafariViewController class. The context attempts to"},{"text":" ","type":"text"},{"type":"text","text":"detect when the user has completed the necessary redirect action by listening"},{"type":"text","text":" "},{"text":"for both app foregrounds and url callbacks received in the app delegate.","type":"text"},{"text":" ","type":"text"},{"text":"However, it is possible the when the redirect is “completed”, the user may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have not actually completed the necessary actions to authorize the charge."},{"type":"text","text":" "},{"text":"You should not use either this class, nor ","type":"text"},{"type":"codeVoice","code":"STPAPIClient"},{"text":", as a way","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to determine when you should charge the Source or to determine if the redirect"},{"text":" ","type":"text"},{"type":"text","text":"was successful. Use Stripe webhooks on your backend server to listen for Source"},{"type":"text","text":" "},{"text":"state changes and to make the charge.","type":"text"}],"role":"symbol","type":"topic"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet":{"abstract":[{"type":"text","text":"PaymentSheet is a prebuilt UI that combines all the steps required to pay - collecting payment details, billing details, and confirming the payment - into a single sheet that displays on top of your app."}],"type":"topic","role":"collection","title":"StripePaymentSheet","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet","kind":"symbol","url":"\/documentation\/stripepaymentsheet"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/STPRedirectContext/SFSafariViewControllerDelegate-Implementations":{"type":"topic","title":"SFSafariViewControllerDelegate Implementations","abstract":[],"url":"\/documentation\/stripepaymentsheet\/stpredirectcontext\/sfsafariviewcontrollerdelegate-implementations","role":"collectionGroup","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPRedirectContext\/SFSafariViewControllerDelegate-Implementations","kind":"article"}}}