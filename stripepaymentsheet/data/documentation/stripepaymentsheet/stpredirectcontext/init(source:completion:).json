ymentSheet\/STPSource","preciseIdentifier":"c:@M@StripePayments@objc(cs)STPSource","text":"STPSource","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"completion","kind":"externalParam"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"STPRedirectContextSourceCompletionBlock","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPRedirectContextSourceCompletionBlock","preciseIdentifier":"s:14StripePayments39STPRedirectContextSourceCompletionBlocka"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"You must ensure that the returnURL set up in the created source"},{"type":"text","text":" "},{"text":"correctly goes to your app so that users can be returned once","type":"text"},{"type":"text","text":" "},{"text":"they complete the redirect in the web broswer.","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parameters:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"source: The source that needs user redirect action to be taken."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"completion: A block to fire when the action is believed to have","type":"text"},{"text":" ","type":"text"},{"text":"been completed.","type":"text"}]}]}],"type":"unorderedList"}]},{"content":[{"inlineContent":[{"text":"Returns: nil if the specified source is not a redirect-flow source. Otherwise","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a new context object."}],"type":"paragraph"}]}]}]},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Execution of the completion block does not necessarily mean the user"},{"text":" ","type":"text"},{"type":"text","text":"successfully performed the redirect action. You should listen for source status"},{"type":"text","text":" "},{"type":"text","text":"change webhooks on your backend to determine the result of a redirect."}],"type":"paragraph"}]}],"kind":"content"}],"sections":[],"abstract":[{"type":"text","text":"Initializer for context from an "},{"code":"STPSource","type":"codeVoice"},{"type":"text","text":"."}],"references":{"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet":{"abstract":[{"type":"text","text":"PaymentSheet is a prebuilt UI that combines all the steps required to pay - collecting payment details, billing details, and confirming the payment - into a single sheet that displays on top of your app."}],"type":"topic","role":"collection","title":"StripePaymentSheet","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet","kind":"symbol","url":"\/documentation\/stripepaymentsheet"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/STPSource":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"STPSource","kind":"identifier"}],"title":"STPSource","type":"topic","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPSource","url":"\/documentation\/stripepaymentsheet\/stpsource","role":"symbol","abstract":[{"type":"text","text":"Representation of a customer’s payment instrument created with the Stripe API. - seealso: https:\/\/stripe.com\/docs\/api#sources"}],"navigatorTitle":[{"text":"STPSource","kind":"identifier"}],"kind":"symbol"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/STPRedirectContext":{"kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPRedirectContext","title":"STPRedirectContext","navigatorTitle":[{"text":"STPRedirectContext","kind":"identifier"}],"url":"\/documentation\/stripepaymentsheet\/stpredirectcontext","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"STPRedirectContext","kind":"identifier"}],"abstract":[{"type":"text","text":"This is a helper class for handling redirects associated with STPSource and"},{"text":" ","type":"text"},{"text":"STPPaymentIntents.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Init and retain an instance with the Source or PaymentIntent you want to handle,"},{"text":" ","type":"text"},{"type":"text","text":"then choose a redirect method. The context will fire the completion handler"},{"text":" ","type":"text"},{"text":"when the redirect completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Due to the nature of iOS, very little concrete information can be gained"},{"type":"text","text":" "},{"text":"during this process, as all actions take place in either the Safari app","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or the sandboxed SFSafariViewController class. The context attempts to"},{"text":" ","type":"text"},{"type":"text","text":"detect when the user has completed the necessary redirect action by listening"},{"type":"text","text":" "},{"text":"for both app foregrounds and url callbacks received in the app delegate.","type":"text"},{"text":" ","type":"text"},{"text":"However, it is possible the when the redirect is “completed”, the user may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have not actually completed the necessary actions to authorize the charge."},{"type":"text","text":" "},{"text":"You should not use either this class, nor ","type":"text"},{"type":"codeVoice","code":"STPAPIClient"},{"text":", as a way","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to determine when you should charge the Source or to determine if the redirect"},{"text":" ","type":"text"},{"type":"text","text":"was successful. Use Stripe webhooks on your backend server to listen for Source"},{"type":"text","text":" "},{"text":"state changes and to make the charge.","type":"text"}],"role":"symbol","type":"topic"},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/STPRedirectContextSourceCompletionBlock":{"identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPRedirectContextSourceCompletionBlock","kind":"symbol","url":"\/documentation\/stripepaymentsheet\/stpredirectcontextsourcecompletionblock","navigatorTitle":[{"kind":"identifier","text":"STPRedirectContextSourceCompletionBlock"}],"type":"topic","role":"symbol","abstract":[{"type":"text","text":"A callback that is executed when the context believes the redirect action has been completed."}],"title":"STPRedirectContextSourceCompletionBlock","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"STPRedirectContextSourceCompletionBlock","kind":"identifier"}]},"doc://com.stripe.stripe-payment-sheet/documentation/StripePaymentSheet/STPRedirectContext/init(source:completion:)":{"type":"topic","identifier":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPRedirectContext\/init(source:completion:)","title":"init(source:completion:)","url":"\/documentation\/stripepaymentsheet\/stpredirectcontext\/init(source:completion:)","fragments":[{"kind":"keyword","text":"convenience"},{"kind":"text","text":" "},{"kind":"identifier","text":"init"},{"kind":"text","text":"?("},{"text":"source","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@M@StripePayments@objc(cs)STPSource","kind":"typeIdentifier","text":"STPSource"},{"text":", ","kind":"text"},{"text":"completion","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"STPRedirectContextSourceCompletionBlock","preciseIdentifier":"s:14StripePayments39STPRedirectContextSourceCompletionBlocka","kind":"typeIdentifier"},{"text":")","kind":"text"}],"abstract":[{"text":"Initializer for context from an ","type":"text"},{"code":"STPSource","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","role":"symbol"}}}