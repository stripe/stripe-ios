{"abstract":[{"type":"text","text":"A boolean number to indicate whether you intend to use the Stripe SDK’s functionality to handle any SetupIntent next actions."},{"text":" ","type":"text"},{"type":"text","text":"If set to false, STPSetupIntent.nextAction will only ever contain a redirect url that can be opened in a webview or mobile browser."},{"type":"text","text":" "},{"text":"When set to true, the nextAction may contain information that the Stripe SDK can use to perform native authentication within your","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"app."}],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"symbol","symbolKind":"property","modules":[{"name":"StripePaymentSheet"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"useStripeSDK","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSNumber","text":"NSNumber","kind":"typeIdentifier"},{"kind":"text","text":"?"}],"title":"useStripeSDK","roleHeading":"Instance Property","externalID":"c:@M@StripePayments@objc(cs)STPSetupIntentConfirmParams(py)useStripeSDK"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet","doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPSetupIntentConfirmParams"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"kind":"attribute","text":"@objc"},{"kind":"text","text":" "},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"useStripeSDK","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"c:objc(cs)NSNumber","kind":"typeIdentifier","text":"NSNumber"},{"kind":"text","text":"?"}]}],"kind":"declarations"}],"identifier":{"url":"doc:\/\/com.stripe.stripe-payment-sheet\/documentation\/StripePaymentSheet\/STPSetupIntentConfirmParams\/useStripeSDK","interfaceLanguage":"swift"},"variants":[{"traits":[{"interf