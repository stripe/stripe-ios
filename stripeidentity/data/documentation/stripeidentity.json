{"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"To get access to the Identity iOS SDK, visit the ","type":"text"},{"isActive":true,"identifier":"https:\/\/dashboard.stripe.com\/settings\/identity","type":"reference"},{"text":" page and click ","type":"text"},{"inlineContent":[{"type":"text","text":"Enable"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}]},{"type":"heading","text":"Table of contents","anchor":"Table-of-contents","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"#Features"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"#Requirements","isActive":true}]}]},{"content":[{"inlineContent":[{"identifier":"#Getting-started","type":"reference","isActive":true}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"identifier":"#Integration","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"#Example","type":"reference"}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"#Manual-linking","type":"reference"}]}]}]},{"type":"heading","text":"Features","anchor":"Features","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Simplified security"}]},{"type":"text","text":": We’ve made it simple for you to securely collect your user’s personally identifiable information (PII) such as identity document images. Sensitive PII data is sent directly to Stripe Identity instead of passing through your server. For more information, see our "},{"type":"reference","identifier":"https:\/\/stripe.com\/docs\/security","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Automatic document capture","type":"text"}]},{"type":"text","text":": We automatically capture images of the front and back of government-issued photo ID to ensure a clear and readable image."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Selfie matching"}]},{"type":"text","text":": We capture photos of your user’s face and review it to confirm that the photo ID belongs to them. For more information, see our guide on "},{"type":"reference","identifier":"https:\/\/stripe.com\/docs\/identity\/selfie","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Identity information collection"}],"type":"strong"},{"text":": We collect name, date of birth, and government ID number to validate that it is real.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Prebuilt UI","type":"text"}],"type":"strong"},{"text":": We provide ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/stripe.dev\/stripe-ios\/stripe-identity\/Classes\/IdentityVerificationSheet.html"},{"text":", a prebuilt UI that combines all the steps required to collect ID documents, selfies, and ID numbers into a single sheet that displays on top of your app.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Automated verification"}],"type":"strong"},{"text":": Stripe Identity’s automated verification technology looks for patterns to help determine if an ID document is real or fake and uses distinctive physiological characteristics of faces to match your users’ selfies to photos on their ID document. Collected identity information is checked against a global set of databases to confirm that it exists. Learn more about the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/stripe.com\/docs\/identity\/verification-checks"},{"text":", ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/stripe.com\/docs\/identity\/access-verification-results"},{"text":", or our integration guide on ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/stripe.com\/docs\/identity\/handle-verification-outcomes"},{"text":".","type":"text"}]},{"type":"heading","level":2,"anchor":"Requirements","text":"Requirements"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Stripe Identity iOS SDK is compatible with apps targeting iOS 13.0 or above."}]},{"type":"paragraph","inlineContent":[{"text":"If you intend to use this SDK with Stripe’s Identity service, you must not modify this SDK. Using a modified version of this SDK with Stripe’s Identity service, without Stripe’s written authorization, is a breach of your agreement with Stripe and may result in your Stripe account being shut down.","type":"text"}]},{"type":"heading","level":2,"anchor":"Getting-started","text":"Getting started"},{"type":"heading","level":3,"anchor":"Integration","text":"Integration"},{"type":"paragraph","inlineContent":[{"text":"Get started with Stripe Identity’s ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/stripe.com\/docs\/identity\/verify-identity-documents?platform=ios"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/stripe\/stripe-ios\/tree\/25.9.0\/StripeIdentity\/..\/Example\/IdentityVerification%20Example"},{"text":", or ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/stripe.dev\/stripe-ios\/stripe-identity\/index.html"},{"text":" for fine-grained documentation of all the classes and methods in the SDK.","type":"text"}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Identity SDK uses camera to scan documents and selfies, you’ll need to set "},{"code":"NSCameraUsageDescription","type":"codeVoice"},{"type":"text","text":" in your application’s plist, and provide a reason for accessing the camera (e.g. “This app uses the camera to take a picture of your identity documents.”)."}]}]},{"type":"heading","level":3,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"text":"Identity Verification Example","type":"text"}],"type":"reference","overridingTitle":"Identity Verification Example","identifier":"https:\/\/github.com\/stripe\/stripe-ios\/tree\/25.9.0\/StripeIdentity\/..\/Example\/IdentityVerification%20Example","isActive":true},{"type":"text","text":" – This example demonstrates how to capture your users’ ID documents on iOS and securely send them to Stripe Identity for identity verification."}]},{"level":2,"anchor":"Manual-linking","type":"heading","text":"Manual linking"},{"type":"paragraph","inlineContent":[{"text":"If you link the Stripe Identity library manually, use a version from our ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/stripe\/stripe-ios\/releases"},{"text":" page and make sure to embed ","type":"text"},{"text":"all","type":"text"},{"text":" of the following frameworks:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"StripeIdentity.xcframework","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"StripeCore.xcframework"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"StripeCameraCore.xcframework","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"StripeUICore.xcframework"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/stripeidentity"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/stripeidentity"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc