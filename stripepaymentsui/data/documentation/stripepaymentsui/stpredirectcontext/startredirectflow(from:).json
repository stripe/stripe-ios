":"and fire its completion block when either the URL is received, or the next"},{"text":" ","type":"text"},{"type":"text","text":"time the app is foregrounded."},{"text":" ","type":"text"},{"type":"text","text":"The context will initiate the flow by presenting a SFSafariViewController"},{"type":"text","text":" "},{"type":"text","text":"instance from the passsed in view controller. If you want more manual control"},{"text":" ","type":"text"},{"type":"text","text":"over the redirect method, you can use "},{"code":"startSafariViewControllerRedirectFlowFromViewController","type":"codeVoice"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"type":"codeVoice","code":"startSafariAppRedirectFlow"},{"type":"text","text":" "},{"type":"text","text":"If the redirect supports a native app, and that app is is installed on the user’s"},{"type":"text","text":" "},{"text":"device, this call will do a direct app-to-app redirect instead of showing","type":"text"},{"type":"text","text":" "},{"text":"a web url.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"@objc","kind":"attribute"},{"kind":"text","text":"(startRedirectFlowFromViewController:) "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"startRedirectFlow"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"from"},{"kind":"text","text":" "},{"text":"presentingViewController","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"UIViewController","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UIViewController"},{"text":")","kind":"text"}],"platforms":["iOS"]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"This method does nothing if the context is no