ect is “completed”, the user may","type":"text"},{"type":"text","text":" "},{"text":"have not actually completed the necessary actions to authorize the charge.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You should not use either this class, nor "},{"code":"STPAPIClient","type":"codeVoice"},{"type":"text","text":", as a way"},{"text":" ","type":"text"},{"type":"text","text":"to determine when you should charge the Source or to determine if the redirect"},{"type":"text","text":" "},{"type":"text","text":"was successful. Use Stripe webhooks on your backend server to listen for Source"},{"text":" ","type":"text"},{"type":"text","text":"state changes and to make the charge."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"STPRedirectContext"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"STPRedirectContext"}],"title":"STPRedirectContext"},"doc://com.stripe.stripe-payments-ui/documentation/StripePaymentsUI/STPRedirectContext/startRedirectFlow(from:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"startRedirectFlow","kind":"identifier"},{"text":"(","kind":"text"},{"text":"from","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:objc(cs)UIViewController","text":"UIViewController","kind":"typeIdentifier"},{"text":")","kind":"text"}],"kind":"symbol","url":"\/documentation\/stripepaymentsui\/stpredirectcontext\/startredirectflow(from:)","role":"symbol","abstract":[{"type":"text","text":"Starts a redirect flow."},{"type":"text","text":" "},{"type":"text","text":"You must ensure that your app delegate listens for  the "},{"type":"codeVoice","code":"returnURL"},{"text":" that you","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"set on the Stripe object, and forwards it to the Stripe SDK so that the"},{"type":"text","text":" "},{"text":"context can be notified when the redirect is completed and dismiss the",