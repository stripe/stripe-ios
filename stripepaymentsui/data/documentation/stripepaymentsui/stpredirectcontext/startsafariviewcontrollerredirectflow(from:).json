cumentation/StripePaymentsUI":{"title":"StripePaymentsUI","url":"\/documentation\/stripepaymentsui","type":"topic","role":"collection","identifier":"doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI","abstract":[{"text":"The StripePaymentsUI module contains UI elements and API bindings for building a custom payment flow using Stripe.","type":"text"}],"kind":"symbol"},"doc://com.stripe.stripe-payments-ui/documentation/StripePaymentsUI/STPRedirectContext/startSafariViewControllerRedirectFlow(from:)":{"kind":"symbol","type":"topic","identifier":"doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI\/STPRedirectContext\/startSafariViewControllerRedirectFlow(from:)","url":"\/documentation\/stripepaymentsui\/stpredirectcontext\/startsafariviewcontrollerredirectflow(from:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"startSafariViewControllerRedirectFlow","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"from"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UIViewController","text":"UIViewController"},{"kind":"text","text":")"}],"abstract":[{"type":"text","text":"Starts a redirect flow by presenting an SFSafariViewController in your app"},{"type":"text","text":" "},{"type":"text","text":"from the passed in view controller."},{"type":"text","text":" "},{"text":"You must ensure that your app delegate listens for  the ","type":"text"},{"type":"codeVoice","code":"returnURL"},{"type":"text","text":" that you"},{"type":"text","text":" "},{"text":"set on the Stripe object, and forwards it to the Stripe SDK so that the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"context can be notified when the redirect is completed and dismiss the"},{"type":"text","text":" "},{"type":"text","text":"view controller. See "},{"type":"codeVoice","code":"StripeAPI.handleStripeURLCallback(with url:)]"},{"type":"text","text":" "},{"type":"text","text":"The context will listen for both received URLs and app open notifications"},{"text":" ","type":"text"},{"text":"and fire its completion block when either the URL is received, or the next","type":"text"},{"text":" ","type":"text"},{"text":"time the app is foregrounded.","type":"text"}],"title":"startSafariViewControllerRedirectFlow(from:)"},"doc://com.stripe.stripe-payments-ui/documentation/StripePaymentsUI/STPRedirectContext":{"identifier":"doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI\/STPRedirectContext","type":"topic","role":"symbol","url":"\/documentation\/stripepaymentsui\/stpredirectcontext","abstract":[{"text":"This is a helper class for handling redirects associated with STPSource and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"STPPaymentIntents."},{"type":"text","text":" "},{"text":"Init and retain an instance with the Source or PaymentIntent you want to handle,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then choose a redirect method. The context will fire the completion handler"},{"type":"text","text":" "},{"type":"text","text":"when the redirect completes."},{"text":" ","type":"text"},{"type":"text","text":"Due to the nature of iOS, very little concrete information can be gained"},{"type":"text","text":" "},{"type":"text","text":"during this process, as all actions take place in either the Safari app"},{"text":" ","type":"text"},{"type":"text","text":"or the sandboxed SFSafariViewController class. The context attempts to"},{"text":" ","type":"text"},{"type":"text","text":"detect when the user has completed the necessary redirect action by listening"},{"type":"text","text":" "},{"type":"text","text":"for both app foregrounds and url callbacks received in the app delegate."},{"text":" ","type":"text"},{"text":"However, it is possible the when the redirect is “completed”, the user may","type":"text"},{"type":"text","text":" "},{"text":"have not actually completed the necessary actions to authorize the charge.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You should not use either this class, nor "},{"code":"STPAPIClient","type":"codeVoice"},{"type":"text","text":", as a way"},{"text":" ","type":"text"},{"type":"text","text":"to determine when you should charge the Source or to determine if the redirect"},{"type":"text","text":" "},{"type":"text","text":"was successful. Use Stripe webhooks on your backend server to listen for Source"},{"text":" ","type":"text"},{"type":"text","text":"state changes and to make the charge."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"STPRedirectContext"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"STPRedirectContext"}],"title":"STPRedirectContext"}}}