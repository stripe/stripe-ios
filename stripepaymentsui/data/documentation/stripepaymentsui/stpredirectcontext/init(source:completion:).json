t":"@escaping"},{"kind":"text","text":" "},{"preciseIdentifier":"s:14StripePayments39STPRedirectContextSourceCompletionBlocka","text":"STPRedirectContextSourceCompletionBlock","kind":"typeIdentifier","identifier":"doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI\/STPRedirectContextSourceCompletionBlock"},{"text":")","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You must ensure that the returnURL set up in the created source"},{"text":" ","type":"text"},{"text":"correctly goes to your app so that users can be returned once","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"they complete the redirect in the web broswer."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parameters:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"source: The source that needs user redirect action to be taken."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"completion: A block to fire when the action is believed to have","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been completed."}],"type":"paragraph"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns: nil if the specified source is not a redirect-flow source. Otherwise"},{"text":" ","type":"text"},{"text":"a new context object.","type":"text"}]}]}]}]},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"Execution of the completion block does not necessarily mean the user"},{"type":"text","text":" "},{"type":"text","text":"successfully performed the redirect action. You should listen for source status"},{"text":" ","type":"text"},{"type":"text","text":"change webhooks on your backend to determine the result of a redirect."}],"type":"paragraph"}],"type":"aside","style":"note"}]}],"hierarchy":{"paths":[["doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI","doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI\/STPRedirectContext"]]},"sections":[],"abstract":[{"type":"text","text":"Initializer for context from an "},{"code":"STPSource","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","references":{"doc://com.stripe.stripe-payments-ui/documentation/StripePaymentsUI/STPRedirectContext/init(source:completion:)":{"abstract":[{"type":"text","text":"Initializer for context from an "},{"code":"STPSource","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI\/STPRedirectContext\/init(source:completion:)","title":"init(source:completion:)","fragments":[{"text":"convenience","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init","kind":"identifier"},{"text":"?(","kind":"text"},{"kind":"externalParam","text":"source"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@M@StripePayments@objc(cs)STPSource","text":"STPSource"},{"kind":"text","text":", "},{"kind":"externalParam","text":"completion"},{"kind":"text","text":": "},{"text":"STPRedirectContextSourceCompletionBlock","preciseIdentifier":"s:14StripePayments39STPRedirectContextSourceCompletionBlocka","kind":"typeIdentifier"},{"kind":"text","text":")"}],"url":"\/documentation\/stripepaymentsui\/stpredirectcontext\/init(source:completion:)","type":"topic","role":"symbol"},"doc://com.stripe.stripe-payments-ui/documentation/StripePaymentsUI":{"title":"StripePaymentsUI","url":"\/documentation\/stripepaymentsui","type":"topic","role":"collection","identifier":"doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI","abstract":[{"text":"The StripePaymentsUI module contains UI elements and API bindings for building a custom payment flow using Stripe.","type":"text"}],"kind":"symbol"},"doc://com.stripe.stripe-payments-ui/documentation/StripePaymentsUI/STPSource":{"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"STPSource"}],"abstract":[{"text":"Representation of a customer’s payment instrument created with the Stripe API. - seealso: https:\/\/stripe.com\/docs\/api#sources","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"STPSource"}],"type":"topic","url":"\/documentation\/stripepaymentsui\/stpsource","title":"STPSource","kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI\/STPSource"},"doc://com.stripe.stripe-payments-ui/documentation/StripePaymentsUI/STPRedirectContext":{"identifier":"doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI\/STPRedirectContext","type":"topic","role":"symbol","url":"\/documentation\/stripepaymentsui\/stpredirectcontext","abstract":[{"text":"This is a helper class for handling redirects associated with STPSource and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"STPPaymentIntents."},{"type":"text","text":" "},{"text":"Init and retain an instance with the Source or PaymentIntent you want to handle,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then choose a redirect method. The context will fire the completion handler"},{"type":"text","text":" "},{"type":"text","text":"when the redirect completes."},{"text":" ","type":"text"},{"type":"text","text":"Due to the nature of iOS, very little concrete information can be gained"},{"type":"text","text":" "},{"type":"text","text":"during this process, as all actions take place in either the Safari app"},{"text":" ","type":"text"},{"type":"text","text":"or the sandboxed SFSafariViewController class. The context attempts to"},{"text":" ","type":"text"},{"type":"text","text":"detect when the user has completed the necessary redirect action by listening"},{"type":"text","text":" "},{"type":"text","text":"for both app foregrounds and url callbacks received in the app delegate."},{"text":" ","type":"text"},{"text":"However, it is possible the when the redirect is “completed”, the user may","type":"text"},{"type":"text","text":" "},{"text":"have not actually completed the necessary actions to authorize the charge.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You should not use either this class, nor "},{"code":"STPAPIClient","type":"codeVoice"},{"type":"text","text":", as a way"},{"text":" ","type":"text"},{"type":"text","text":"to determine when you should charge the Source or to determine if the redirect"},{"type":"text","text":" "},{"type":"text","text":"was successful. Use Stripe webhooks on your backend server to listen for Source"},{"text":" ","type":"text"},{"type":"text","text":"state changes and to make the charge."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"STPRedirectContext"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"STPRedirectContext"}],"title":"STPRedirectContext"},"doc://com.stripe.stripe-payments-ui/documentation/StripePaymentsUI/STPRedirectContextSourceCompletionBlock":{"type":"topic","kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-payments-ui\/documentation\/StripePaymentsUI\/STPRedirectContextSourceCompletionBlock","role":"symbol","url":"\/documentation\/stripepaymentsui\/stpredirectcontextsourcecompletionblock","title":"STPRedirectContextSourceCompletionBlock","abstract":[{"type":"text","text":"A callback that is executed when the context believes the redirect action has been completed."}],"fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"STPRedirectContextSourceCompletionBlock"}],"navigatorTitle":[{"text":"STPRedirectContextSourceCompletionBlock","kind":"identifier"}]}}}