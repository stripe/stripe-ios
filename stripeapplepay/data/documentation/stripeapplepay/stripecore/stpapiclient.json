ic","identifier":"doc:\/\/com.stripe.stripe-apple-pay\/documentation\/StripeApplePay\/StripeCore\/STPAPIClient\/pkPaymentError(forStripeError:)","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"pkPaymentError","kind":"identifier"},{"text":"(","kind":"text"},{"text":"forStripeError","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Error","kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP"},{"text":"?) -> ","kind":"text"},{"text":"Error","kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP"},{"text":"?","kind":"text"}],"title":"pkPaymentError(forStripeError:)","role":"symbol","abstract":[{"text":"Converts Stripe errors into the appropriate Apple Pay error, for use in ","type":"text"},{"type":"codeVoice","code":"PKPaymentAuthorizationResult"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If the error can be fixed by the customer within the Apple Pay sheet, we return an NSError that can be displayed in the Apple Pay sheet.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise, the original error is returned, resulting in the Apple Pay sheet being dismissed. You should display the error message to the customer afterwards.","type":"text"},{"text":" ","type":"text"},{"text":"Currently, we convert billing address related errors into a PKPaymentError that helpfully points to the billing address field in the Apple Pay sheet.","type":"text"},{"text":" ","type":"text"},{"text":"Note that Apple Pay should prevent most card errors (e.g. invalid CVC, expired cards) when you add a card to the wallet.","type":"text"}]},"doc://com.stripe.stripe-apple-pay/documentation/StripeApplePay/StripeCore/STPAPIClient":{"navigatorTitle":[{"kind":"identifier","text":"STPAPIClient"}],"kind":"symbol","title":"STPAPIClient","url":"\/documentation\/stripeapplepay\/stripecore\/stpapiclient","identifier":"doc:\/\/com.stripe.stripe-apple-pay\/document