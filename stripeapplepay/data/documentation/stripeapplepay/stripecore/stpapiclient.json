n\/stripeapplepay\/stripecore\/stpapiclient\/pkpaymenterror(forstripeerror:)","abstract":[{"text":"Converts Stripe errors into the appropriate Apple Pay error, for use in ","type":"text"},{"type":"codeVoice","code":"PKPaymentAuthorizationResult"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If the error can be fixed by the customer within the Apple Pay sheet, we return an NSError that can be displayed in the Apple Pay sheet.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise, the original error is returned, resulting in the Apple Pay sheet being dismissed. You should display the error message to the customer afterwards.","type":"text"},{"text":" ","type":"text"},{"text":"Currently, we convert billing address related errors into a PKPaymentError that helpfully points to the billing address field in the Apple Pay sheet.","type":"text"},{"text":" ","type":"text"},{"text":"Note that Apple Pay should prevent most card errors (e.g. invalid CVC, expired cards) when you add a card to the wallet.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"pkPaymentError"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forStripeError"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Error","preciseIdentifier":"s:s5ErrorP"},{"kind":"text","text":"?) -> "},{"kind":"typeIdentifier","text":"Error","preciseIdentifier":"s:s5ErrorP"},{"kind":"text","text":"?"}],"identifier":"doc:\/\/com.stripe.stripe-apple-pay\/documentation\/StripeApplePay\/StripeCore\/STPAPIClient\/pkPaymentError(forStripeError:)"},"doc://com.stripe.stripe-apple-pay/documentation/StripeApplePay/StripeCore":{"url":"\/documentation\/stripeapplepay\/stripecore","kind":"symbol","title":"StripeCore","abstract":[],"identifier":"doc:\/\/com.stripe.stripe-apple-pay\/documentation\/StripeApplePay\/StripeCore","type":"topic","role":"collection"},"doc://