{"hierarchy":{"paths":[["doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe","doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContext"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/stripe\/stpredirectcontext\/startsafariviewcontrollerredirectflow(from:)"]}],"abstract":[{"text":"Starts a redirect flow by presenting an SFSafariViewController in your app","type":"text"},{"text":" ","type":"text"},{"text":"from the passed in view controller.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You must ensure that your app delegate listens for  the "},{"type":"codeVoice","code":"returnURL"},{"text":" that you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"set on the Stripe object, and forwards it to the Stripe SDK so that the"},{"text":" ","type":"text"},{"type":"text","text":"context can be notified when the redirect is completed and dismiss the"},{"type":"text","text":" "},{"text":"view controller. See ","type":"text"},{"type":"codeVoice","code":"StripeAPI.handleStripeURLCallback(with url:)]"},{"type":"text","text":" "},{"text":"The context will listen for both received URLs and app open notifications","type":"text"},{"type":"text","text":" "},{"text":"and fire its completion block when either the URL is received, or the next","type":"text"},{"type":"text","text":" "},{"text":"time the app is foregrounded.","type":"text"}],"kind":"symbol","metadata":{"modules":[{"name":"Stripe"}],"externalID":"c:@M@StripePayments@objc(cs)STPRedirectContext(im)startSafariViewControllerRedirectFlowFromViewController:","title":"startSafariViewControllerRedirectFlow(from:)","role":"symbol","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"startSafariViewControllerRedirectFlow","kind":"identifier"},{"text":"(","kind":"text"},{"text":"from","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","p