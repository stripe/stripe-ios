" ","kind":"text"},{"identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContextSourceCompletionBlock","text":"STPRedirectContextSourceCompletionBlock","preciseIdentifier":"s:14StripePayments39STPRedirectContextSourceCompletionBlocka","kind":"typeIdentifier"},{"text":")","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You must ensure that the returnURL set up in the created source"},{"type":"text","text":" "},{"type":"text","text":"correctly goes to your app so that users can be returned once"},{"text":" ","type":"text"},{"text":"they complete the redirect in the web broswer.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Parameters:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"source: The source that needs user redirect action to be taken."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"completion: A block to fire when the action is believed to have","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been completed."}]}]}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Returns: nil if the specified source is not a redirect-flow source. Otherwise"},{"text":" ","type":"text"},{"text":"a new context object.","type":"text"}],"type":"paragraph"}]}]}],"type":"aside","name":"Note"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"Execution of the completion block does not necessarily mean the user","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"successfully performed the redirect action. You should listen for source status"},{"text":" ","type":"text"},{"text":"change webhooks on your backend to determine the result of a redirect.","type":"text"}],"type":"paragraph"}]}]}],"variants":[{"paths":["\/documentation\/stripe\/stpredirectcontext\/init(source:completion:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","abstract":[{"text":"Initializer for context from an ","type":"text"},{"code":"STPSource","type":"codeVoice"},{"text":".","type":"text"}],"references":{"doc://com.stripe.stripe-ios/documentation/Stripe/STPRedirectContext":{"url":"\/documentation\/stripe\/stpredirectcontext","title":"STPRedirectContext","role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContext","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"STPRedirectContext","kind":"identifier"}],"navigatorTitle":[{"text":"STPRedirectContext","kind":"identifier"}],"abstract":[{"type":"text","text":"This is a helper class for handling redirects associated with STPSource and"},{"type":"text","text":" "},{"text":"STPPaymentIntents.","type":"text"},{"text":" ","type":"text"},{"text":"Init and retain an instance with the Source or PaymentIntent you want to handle,","type":"text"},{"text":" ","type":"text"},{"text":"then choose a redirect method. The context will fire the completion handler","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when the redirect completes."},{"text":" ","type":"text"},{"text":"Due to the nature of iOS, very little concrete information can be gained","type":"text"},{"type":"text","text":" "},{"text":"during this process, as all actions take place in either the Safari app","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or the sandboxed SFSafariViewController class. The context attempts to"},{"text":" ","type":"text"},{"type":"text","text":"detect when the user has completed the necessary redirect action by listening"},{"type":"text","text":" "},{"type":"text","text":"for both app foregrounds and url callbacks received in the app delegate."},{"type":"text","text":" "},{"type":"text","text":"However, it is possible the when the redirect is “completed”, the user may"},{"text":" ","type":"text"},{"text":"have not actually completed the necessary actions to authorize the charge.","type":"text"},{"type":"text","text":" "},{"text":"You should not use either this class, nor ","type":"text"},{"code":"STPAPIClient","type":"codeVoice"},{"text":", as a way","type":"text"},{"type":"text","text":" "},{"text":"to determine when you should charge the Source or to determine if the redirect","type":"text"},{"text":" ","type":"text"},{"text":"was successful. Use Stripe webhooks on your backend server to listen for Source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state changes and to make the charge."}]},"doc://com.stripe.stripe-ios/documentation/Stripe/STPSource":{"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"STPSource","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"STPSource"}],"identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPSource","url":"\/documentation\/stripe\/stpsource","abstract":[{"type":"text","text":"Representation of a customer’s payment instrument created with the Stripe API. - seealso: https:\/\/stripe.com\/docs\/api#sources"}],"type":"topic","kind":"symbol","title":"STPSource"},"doc://com.stripe.stripe-ios/documentation/Stripe/STPRedirectContext/init(source:completion:)":{"identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContext\/init(source:completion:)","kind":"symbol","type":"topic","url":"\/documentation\/stripe\/stpredirectcontext\/init(source:completion:)","abstract":[{"text":"Initializer for context from an ","type":"text"},{"code":"STPSource","type":"codeVoice"},{"text":".","type":"text"}],"title":"init(source:completion:)","role":"symbol","fragments":[{"kind":"keyword","text":"convenience"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init"},{"text