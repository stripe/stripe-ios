ContextState","kind":"typeIdentifier","text":"STPRedirectContextState"}],"identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContext\/state","role":"symbol","kind":"symbol","type":"topic","url":"\/documentation\/stripe\/stpredirectcontext\/state","title":"state","abstract":[{"text":"The current state of the context.","type":"text"}]},"doc://com.stripe.stripe-ios/documentation/Stripe/STPRedirectContext":{"url":"\/documentation\/stripe\/stpredirectcontext","title":"STPRedirectContext","role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContext","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"STPRedirectContext","kind":"identifier"}],"navigatorTitle":[{"text":"STPRedirectContext","kind":"identifier"}],"abstract":[{"type":"text","text":"This is a helper class for handling redirects associated with STPSource and"},{"type":"text","text":" "},{"text":"STPPaymentIntents.","type":"text"},{"text":" ","type":"text"},{"text":"Init and retain an instance with the Source or PaymentIntent you want to handle,","type":"text"},{"text":" ","type":"text"},{"text":"then choose a redirect method. The context will fire the completion handler","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when the redirect completes."},{"text":" ","type":"text"},{"text":"Due to the nature of iOS, very little concrete information can be gained","type":"text"},{"type":"text","text":" "},{"text":"during this process, as all actions take place in either the Safari app","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or the sandboxed SFSafariViewController class. The context attempts to"},{"text":" ","type":"text"},{"type":"text","text":"detect when the user has completed the necessary redirect action by listening"},{"type":"text","text":" "},{"type":"text","text":"for both app foregrounds and url callbacks received in the app delegate."},{"type":"text","text":" "},{"type":"text","text":"However, it is possible the when the redirect is “completed”, the user may"},{"text":" ","type":"text"},{"text":"have not actually completed the necessary actions to authorize the charge.","type":"text"},{"type":"text","text":" "},{"text":"You should not use either this class, nor ","type":"text"},{"code":"STPAPIClient","type":"codeVoice"},{"text":", as a way","type":"text"},{"type":"text","text":" "},{"text":"to determine when you should charge the Source or to determine if the redirect","type":"text"},{"text":" ","type":"text"},{"text":"was successful. Use Stripe webhooks on your backend server to listen for Source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state changes and to make the charge."}]},"doc://com.stripe.stripe-ios/documentation/Stripe/STPRedirectContextState":{"navigatorTitle":[{"kind":"identifier","text":"STPRedirectContextState"}],"role":"symbol","abstract":[{"type":"text","text":"Possible states for the redirect context to be in"}],"kind":"symbol","url":"\/documentation\/stripe\/stpredirectcontextstate","title":"STPRedirectContextState","type":"topic","identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContextState","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"STPRedirectContextState","kind":"identifier"}]},"doc://com.stripe.stripe-ios/documentation/Stripe":{"type":"topic","url":"\/documentation\/stripe","title":"Stripe","kind":"symbol","role":"collection","identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe","abstract":[]}}}