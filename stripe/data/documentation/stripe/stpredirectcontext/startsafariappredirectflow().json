{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"kind":"text","text":" "},{"text":"@objc","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"startSafariAppRedirectFlow"},{"text":"()","kind":"text"}],"platforms":["iOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This method does nothing if the context is not in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"STPRedirectContextStateNotStarted"},{"type":"text","text":" state."}]}],"name":"Note","style":"note"}],"kind":"content"}],"metadata":{"role":"symbol","modules":[{"name":"Stripe"}],"symbolKind":"method","roleHeading":"Instance Method","externalID":"c:@M@StripePayments@objc(cs)STPRedirectContext(im)startSafariAppRedirectFlow","title":"startSafariAppRedirectFlow()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"startSafariAppRedirectFlow","kind":"identifier"},{"text":"()","kind":"text"}]},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe","doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContext"]]},"kind":"symbol","abstract":[{"type":"text","text":"Starts a redirect flow by calling "},{"type":"codeVoice","code":"openURL"},{"text":" to bounce the user out to","type":"text"},{"text":" ","type":"text"},{"text":"the Safari app.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The context will listen for app open notifications and fire its completion"},{"text":" ","type":"text"},{"type":"text","text":"block the next time the user re-opens the app (either manually or via url)"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContext\/startSafariAppRedirectFlow()"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/stripe\/stpredirectcontext\/startsafariappredirectflow()"]}],"references":{"doc://com.stripe.stripe-ios/documentation/Stripe/STPRedirectContext":{"url":"\/documentation\/stripe\/stpredirectcontext","title":"STPRedirectContext","role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContext","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"STPRedirectContext","kind":"identifier"}],"navigatorTitle":[{"text":"STPRedirectContext","kind":"identifier"}],"abstract":[{"type":"text","text":"This is a helper class for handling redirects associated with STPSource and"},{"type":"text","text":" "},{"text":"STPPaymentIntents.","type":"text"},{"text":" ","type":"text"},{"text":"Init and retain an instance with the Source or PaymentIntent you want to handle,","type":"text"},{"text":" ","type":"text"},{"text":"then choose a redirect method. The context will fire the completion handler","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when the redirect completes."},{"text":" ","type":"text"},{"text":"Due to the nature of iOS, very little concrete information can be gained","type":"text"},{"type":"text","text":" "},{"text":"during this process, as all actions take place in either the Safari app","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or the sandboxed SFSafariViewController class. The context attempts to"},{"text":" ","type":"text"},{"type":"text","text":"detect when the user has completed the necessary redirect action by listening"},{"type":"text","text":" "},{"type":"text","text":"for both app foregrounds and url callbacks received in the app delegate."},{"type":"text","text":" "},{"type":"text","text":"However, it is possible the when the redirect is “completed”, the user may"},{"text":" ","type":"text"},{"text":"have not actually completed the necessary actions to authorize the charge.","type":"text"},{"type":"text","text":" "},{"text":"You should not use either this class, nor ","type":"text"},{"code":"STPAPIClient","type":"codeVoice"},{"text":", as a way","type":"text"},{"type":"text","text":" "},{"text":"to determine when you should charge the Source or to determine if the redirect","type":"text"},{"text":" ","type":"text"},{"text":"was successful. Use Stripe webhooks on your backend server to listen for Source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state changes and to make the charge."}]},"doc://com.stripe.stripe-ios/documentation/Stripe/STPRedirectContext/startSafariAppRedirectFlow()":{"identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPRedirectContext\/startSafariAppRedirectFlow()","role":"symbol","type":"topic","abstract":[{"type":"text","text":"Starts a redirect flow by calling "},{"type":"codeVoice","code":"openURL"},{"type":"text","text":" to bounce the user out to"},{"type":"text","text":" "},{"type":"text","text":"the Safari app."},{"type":"text","text":" "},{"text":"The context will listen for app open notifications and fire its completion","type":"text"},{"type":"text","text":" "},{"type":"text","text":"block the next time the user re-opens the app (either manually or via url)"}],"kind":"symbol","url":"\/documentation\/stripe\/stpredirectcontext\/startsafariappredirectflow()","title":"startSafariAppRedirectFlow()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"startSafariAppRedirectFlow"},{"text":"()","kind":"text"}]},"doc://com.stripe.stripe-ios/documentation/Stripe":{"type":"topic","url":"\/documentation\/stripe","title":"Stripe","kind":"symbol","role":"collection","identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe","abstract":[]}}}