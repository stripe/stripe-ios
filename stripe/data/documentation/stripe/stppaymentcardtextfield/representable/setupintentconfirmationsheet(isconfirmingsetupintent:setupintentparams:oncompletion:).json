ind":"keyword"},{"text":" ","kind":"text"},{"text":"STPSetupIntentConfirmParams","kind":"identifier"}],"abstract":[{"text":"An object representing parameters to confirm a SetupIntent object.","type":"text"},{"text":" ","type":"text"},{"text":"For example, you would confirm a SetupIntent when a customer hits the “Save” button on a payment method management view in your app.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If the selected payment method does not require any additional steps from the customer, the SetupIntent’s status will transition to "},{"code":"STPSetupIntentStatusSucceeded","type":"codeVoice"},{"type":"text","text":".  Otherwise, it will transition to "},{"type":"codeVoice","code":"STPSetupIntentStatusRequiresAction"},{"type":"text","text":", and suggest additional actions via "},{"code":"nextAction","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Instead of passing this to ","type":"text"},{"type":"codeVoice","code":"STPAPIClient.confirmSetupIntent(...)"},{"text":" directly, we recommend using ","type":"text"},{"type":"codeVoice","code":"STPPaymentHandler"},{"text":" to handle any additional steps for you.","type":"text"}],"type":"topic","role":"symbol"},"doc://com.stripe.stripe-ios/documentation/Stripe/STPPaymentCardTextField/Representable":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Representable"}],"kind":"symbol","title":"STPPaymentCardTextField.Representable","type":"topic","abstract":[{"type":"text","text":"A SwiftUI representation of an STPPaymentCardTextField."}],"url":"\/documentation\/stripe\/stppaymentcardtextfield\/representable","role":"symbol","identifier":"doc:\/\/com.stripe.stripe-ios\/documentation\/Stripe\/STPPaymentCardTextField\/Representable","navigatorTitle":[{"kind":"identifier","text":"Representable"}]},"doc://com.stripe.stripe-ios/documentation/Stripe/STPPaymentHandlerActionSetupIntentCompletionBlock":{"type":"