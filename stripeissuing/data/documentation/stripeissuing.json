wcontroller","abstract":[{"type":"text","text":"This class is a piece of fake UI that is intended to mimic "},{"type":"codeVoice","code":"PKAddPaymentPassViewController"},{"type":"text","text":". That class is restricted to apps with a special entitlement from Apple, and as such can be difficult to build and test against. This class implements the same public API as "},{"type":"codeVoice","code":"PKAddPaymentPassViewController"},{"type":"text","text":", and can be used to develop against the Stripe API in "},{"inlineContent":[{"text":"testmode only","type":"text"}],"type":"emphasis"},{"type":"text","text":". (Obviously it will not actually place cards into the user’s Apple Pay wallet either.) When it’s time to go to production, you may simply replace all references to "},{"type":"codeVoice","code":"STPFakeAddPaymentPassViewController"},{"type":"text","text":" in your app with "},{"type":"codeVoice","code":"PKAddPaymentPassViewController"},{"type":"text","text":" and it will continue to function. For more information on developing against this API, please see https:\/\/stripe.com\/docs\/issuing\/cards\/digital-wallets ."}],"role":"symbol","title":"STPFakeAddPaymentPassViewController","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"STPFakeAddPaymentPassViewController","kind":"identifier"}],"navigatorTitle":[{"text":"STPFakeAddPaymentPassViewController","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.stripe.stripe-issuing-push-provision\/documentation\/StripeIssuing\/STPFakeAddPaymentPassViewController"},"#Features":{"title":"Features","url":"#Features","type":"link","titleInlineContent":[{"text":"Features","type":"text"}],"identifier":"#Features"},"doc://com.stripe.stripe-issuing-push-provision/documentation/StripeIssuing/STPPushProvisioningContext":{"kind":"symbol","navigatorTitle":[{"text":"STPPushProvisioningContext","kind":"identifier"}],"url":"\/documentation\/stripeissuing\/stppushprovisioningcont