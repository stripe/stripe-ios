 This class implements the same public API as "},{"code":"PKAddPaymentPassViewController","type":"codeVoice"},{"type":"text","text":", and can be used to develop against the Stripe API in "},{"inlineContent":[{"type":"text","text":"testmode only"}],"type":"emphasis"},{"type":"text","text":". (Obviously it will not actually place cards into the user’s Apple Pay wallet either.) When it’s time to go to production, you may simply replace all references to "},{"code":"STPFakeAddPaymentPassViewController","type":"codeVoice"},{"type":"text","text":" in your app with "},{"code":"PKAddPaymentPassViewController","type":"codeVoice"},{"type":"text","text":" and it will continue to function. For more information on developing against this API, please see https:\/\/stripe.com\/docs\/issuing\/cards\/digital-wallets ."}],"navigatorTitle":[{"kind":"identifier","text":"STPFakeAddPaymentPassViewController"}]},"doc://com.stripe.stripe-issuing-push-provision/documentation/StripeIssuing":{"identifier":"doc:\/\/com.stripe.stripe-issuing-push-provision\/documentation\/StripeIssuing","kind":"symbol","title":"StripeIssuing","type":"topic","abstract":[{"type":"text","text":"Placeholder"}],"url":"\/documentation\/stripeissuing","role":"collection"},"#Example":{"titleInlineContent":[{"type":"text","text":"Example"}],"type":"link","url":"#Example","identifier":"#Example","title":"Example"},"#Integration":{"titleInlineContent":[{"type":"text","text":"Integration"}],"type":"link","url":"#Integration","identifier":"#Integration","title":"Integration"},"doc://com.stripe.stripe-issuing-push-provision/documentation/StripeIssuing/StripeIssuingVersionNumber":{"fragments":[{"kind":"identifier","text":"StripeIssuingVersionNumber"}],"role":"symbol","url":"\/documentation\/stripeissuing\/stripeissuingversionnumber","identifier":"doc:\/\/com.stripe.stripe-issuing-push-provision\/documentation\/StripeIssuing\/StripeIssuingVersionNumber","type":"topic","title":"StripeIssuingVersionNumber","kind":"symbol","abst