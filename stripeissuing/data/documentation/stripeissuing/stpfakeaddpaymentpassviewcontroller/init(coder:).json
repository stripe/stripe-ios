r app with ","type":"text"},{"type":"codeVoice","code":"PKAddPaymentPassViewController"},{"text":" and it will continue to function. For more information on developing against this API, please see https:\/\/stripe.com\/docs\/issuing\/cards\/digital-wallets .","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"STPFakeAddPaymentPassViewController","kind":"identifier"}]},"doc://com.stripe.stripe-issuing-push-provision/documentation/StripeIssuing":{"title":"StripeIssuing","identifier":"doc:\/\/com.stripe.stripe-issuing-push-provision\/documentation\/StripeIssuing","abstract":[{"type":"text","text":"Placeholder"}],"type":"topic","kind":"symbol","role":"collection","url":"\/documentation\/stripeissuing"}}}