{"hierarchy":{"paths":[[]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"This library provides a user interface through which users can scan payment cards and extract information from them. It uses the Stripe Publishable Key to authenticate with Stripe services.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note that this is a standalone SDK and, while compatible with, does not directly integrate with the ","type":"text"},{"identifier":"https:\/\/stripe.com\/docs\/api\/payment_intents","isActive":true,"type":"reference"},{"text":" API nor with ","type":"text"},{"identifier":"https:\/\/stripe.com\/docs\/api\/errors#errors-payment_intent-next_action","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This library can be used entirely outside of a Stripe integration and with other payment processing providers.","type":"text"}],"type":"paragraph"},{"anchor":"Requirements","level":2,"text":"Requirements","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS 15.0 or higher"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Xcode 15 or higher"}]}]}],"type":"unorderedList"},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"inlineContent":[{"text":"See the ","type":"text"},{"identifier":"https:\/\/github.com\/stripe\/stripe-ios\/tree\/master\/Example\/CardImageVerification%20Example","isActive":true,"type":"reference"},{"text":" directory for an example application that you can try for yourself!","type":"text"}],"type":"paragraph"},{"anchor":"Installation","level":2,"text":"Installation","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cocoapod"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pod install StripeCardScan"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"SPM"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, select File > Add Packages… and enter https:\/\/github.com\/stripe\/stripe-ios-spm as the repository URL."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the latest version number from our releases page."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the "},{"type":"codeVoice","code":"StripeCardScan"},{"type":"text","text":" product to the target of your app."}]}]}]}]}],"type":"unorderedList"},{"anchor":"Integration","level":2,"text":"Integration","type":"heading"},{"anchor":"Credit-Card-OCR","level":3,"text":"Credit Card OCR","type":"heading"},{"inlineContent":[{"text":"Add ","type":"text"},{"type":"codeVoice","code":"CardScanSheet"},{"text":" in your view controller where you want to invoke the credit card scanning flow.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set up camera permissions"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK uses the camera, so you’ll need to add an description of camera usage to your Info.plist file:"},{"type":"text","text":" "},{"type":"image","identifier":"https:\/\/gblobscdn.gitbook.com\/assets\/-MAfqrnL3d-uke0sAFsI\/sync\/573e3f05043e4d903189b5fb107d4b3565bdb11b.png?alt=media"},{"type":"text","text":" "},{"type":"image","identifier":"https:\/\/gblobscdn.gitbook.com\/assets\/-MAfqrnL3d-uke0sAFsI\/sync\/0d7119d3cbe2f519e5e5c04b56fe43539e4435e1.png?alt=media"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, you can add this permission directly to your Info.plist file:"}]}]}]},{"code":["<key>NSCameraUsageDescriptionkey>","<string>We need access to your camera to scan your cardstring>"],"type":"codeListing","syntax":null}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add "},{"type":"codeVoice","code":"CardScanSheet"},{"type":"text","text":" in your app where you want to invoke the scan flow"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Initialize "},{"type":"codeVoice","code":"CardScanSheet"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When it’s time to invoke the scan flow, display the sheet with "},{"type":"codeVoice","code":"CardScanSheet.present()"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When the verification flow is finished, the sheet will be dismissed and the completion block will be called with a "},{"type":"reference","identifier":"https:\/\/stripe.dev\/stripe-ios\/","isActive":true}]}]}]}]}],"type":"orderedList"},{"anchor":"Example-Implementation","level":3,"text":"Example Implementation","type":"heading"},{"syntax":"swift","code":["","import UIKit","import StripeCardScan","","class ViewController: UIViewController {","","    @IBAction func cardScanSheetButtonPressed() {","        let cardScanSheet = CardScanSheet()","","        cardScanSheet.present(from: self) { [weak self] result in","            switch result {","                case .completed(let scannedCard):","                \/*","                 * The user scanned a card. The result of the scan are detailed ","                 * in the `scannedCard` field of the result.","                 *\/","                print(\"scan success\")","            case .canceled:","                \/*","                * The scan was canceled by the user.","                *\/","                print(\"scan canceled\")","            case .failed(let error):","                 \/*","                 * The scan failed. The displayable error is","                 * included in the `localizedDescription`.