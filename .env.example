# Stripe iOS SDK - Local Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.
#
# direnv will automatically load .env when you cd into this directory.
# First time: brew install direnv, then run `direnv allow` in this repo.

# Bitrise Personal Access Token (required for /babysit-pr)
# Get yours at: https://app.bitrise.io/me/profile#/security
# Under "Personal Access Tokens", click "Generate new token"
BITRISE_TOKEN=
